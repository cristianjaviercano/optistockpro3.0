rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - totalScore: number (required)
    //   - level: number (required)
    //   - completedChallenges: list (required)
    //
    // Collection: challenges
    // Document ID: {challengeId}
    // Fields:
    //   - id: string (required)
    //   - slotId: number (required)
    //   - title: string (required)
    //   - description: string (required)
    //   - targetPallets: number (required)
    //   - timeLimit: number (required)
    //   - baseScore: number (required)
    //
    // Collection: runs
    // Document ID: {runId}
    // Fields:
    //   - userId: string (required)
    //   - challengeId: string (required)
    //   - score: number (required)
    //   - timeTaken: number (required)
    //   - fuelUsed: number (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "msccristianjcanom@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'totalScore', 'level', 'completedChallenges']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.totalScore is number && data.totalScore >= 0 &&
             data.level is number && data.level >= 1 &&
             data.completedChallenges is list;
    }

    function isValidRun(data) {
      return data.keys().hasAll(['userId', 'challengeId', 'score', 'timeTaken', 'fuelUsed', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.challengeId is string &&
             data.score is number && data.score >= 0 &&
             data.timeTaken is number && data.timeTaken >= 0 &&
             data.fuelUsed is number && data.fuelUsed >= 0 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid) || isAdmin();
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /runs/{runId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRun(request.resource.data);
      allow update: if isAdmin();
    }
  }
}
